# Environment Variables for Docker Compose
# Copy this file to .env and customize as needed

# PostgreSQL Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=co_founder_db
POSTGRES_PORT=5433

# Redis Configuration
REDIS_PORT=6379

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# API Configuration
API_PORT=3001
NODE_ENV=development

# Database URL (used by API)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://admin:password@postgres:5432/co_founder_db

# Redis URL (used by API for BullMQ, cache, etc.)
REDIS_URL=redis://redis:6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=co-founder-avatars

# Firebase Admin SDK (Backend Authentication)
FIREBASE_PROJECT_ID=co-founder-babf6
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@co-founder-babf6.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
