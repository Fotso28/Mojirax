// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// --------------------------------------
// 1. User & Authentication (NextAuth)
// --------------------------------------

enum UserRole {
  ADMIN
  USER
}

enum AccountStatus {
  ACTIVE
  BANNED
}

enum UserPlan {
  FREE
  PLUS
  PRO
  ELITE
}

model User {
  id String @id @default(cuid())

  // Contact Info
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  name          String? // Full name (computed or from OAuth)
  email         String    @unique
  phone         String? // Format: +237XXXXXXXXX
  address       String? // Full address
  emailVerified DateTime? @map("email_verified")
  firebaseUid   String?   @unique @map("firebase_uid") // Firebase Auth UID

  // Profile
  image String? // Avatar URL (R2)

  // Professional Profile (promoted from founderProfile JSON)
  title             String?
  bio               String?   @db.Text
  country           String?
  city              String?
  linkedinUrl       String?   @map("linkedin_url")
  websiteUrl        String?   @map("website_url")
  githubUrl         String?   @map("github_url")
  portfolioUrl      String?   @map("portfolio_url")
  skills            String[]  @default([])
  languages         String[]  @default([])
  certifications    String[]  @default([])
  yearsOfExperience Int?      @map("years_of_experience")
  experience        Json?     @db.JsonB
  education         Json?     @db.JsonB

  role   UserRole      @default(USER)
  status AccountStatus @default(ACTIVE)

  plan                 UserPlan  @default(FREE)
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  planExpiresAt        DateTime? @map("plan_expires_at")
  planStartedAt        DateTime? @map("plan_started_at")
  isInvisible          Boolean   @default(false) @map("is_invisible")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Onboarding Draft State
  onboardingState Json? @map("onboarding_state") // Stores { step: 2, data: {...} }
  projectDraft    Json? @map("project_draft") // Stores { step: 3, data: {...} } for /create/project wizard

  // Relations
  accounts Account[]
  sessions Session[]

  // Profile Relations
  candidateProfile CandidateProfile?
  projects         Project[]

  // Monetization
  transactions        Transaction[]
  unlocks             Unlock[]
  notifications       Notification[]
  adminLogs           AdminLog[]
  searchLogs          SearchLog[]
  projectInteractions UserProjectInteraction[]
  visits              UserVisit[]
  fcmTokens           FcmToken[]
  emailLogs           EmailLog[]

  // Messaging
  founderConversations   Conversation[]    @relation("FounderConversations")
  candidateConversations Conversation[]    @relation("CandidateConversations")
  sentMessages           Message[]         @relation("SentMessages")
  messageReactions       MessageReaction[] @relation("MessageReactions")

  // Profile Views
  profileViewsSent     ProfileView[] @relation("ProfileViewer")
  profileViewsReceived ProfileView[] @relation("ProfileViewed")

  // Boosts
  boosts Boost[]

  // Preferences
  preferredLang String @default("fr") @map("preferred_lang")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --------------------------------------
// 2. Profiles & Domain Entities
// --------------------------------------

enum ModerationStatus {
  DRAFT
  ANALYZING
  PENDING_AI
  PUBLISHED
  REJECTED
  REMOVED_BY_ADMIN
}

model CandidateProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  // Core Data (title, bio, skills, etc. now live on User)
  resumeUrl   String? @map("resume_url") // R2 Link

  // Wizard-sourced fields (stored separately for round-trip editing)
  shortPitch     String? @map("short_pitch") @db.Text
  longPitch      String? @map("long_pitch") @db.Text
  vision         String? @db.Text
  roleType       String? @map("role_type") // TECH, PRODUCT, MARKETING, OPS, FINANCE
  commitmentType String? @map("commitment_type") // SIDE, SERIOUS, FULLTIME
  collabPref     String? @map("collab_pref") // EQUITY, PAID, HYBRID, DISCUSS
  locationPref   String? @map("location_pref") // REMOTE, HYBRID, ONSITE
  hasCofounded   String? @map("has_cofounded") // YES, NO

  // Matching Preferences
  desiredSectors    String[] @default([]) @map("desired_sectors") // ["Fintech", "Health"]
  desiredStage      String[] @default([]) @map("desired_stage") // ["MVP", "Growth"]
  desiredLocation   String[] @default([]) @map("desired_location") // ["Douala", "Remote"]
  minSalary         Int?     @map("min_salary")
  maxSalary         Int?     @map("max_salary")
  availability      String? // "IMMEDIATE", "1_MONTH", "3_MONTHS"
  willingToRelocate Boolean  @default(false) @map("willing_to_relocate")
  remoteOnly        Boolean  @default(false) @map("remote_only")

  // Privacy & Monetization
  isContactVisible Boolean @default(false) @map("is_contact_visible")

  // Moderation
  status ModerationStatus @default(DRAFT)

  // AI Search & Scoring
  bioEmbedding     Unsupported("vector(1024)")? @map("bio_embedding")
  skillsEmbedding  Unsupported("vector(1024)")? @map("skills_embedding")
  embeddingModel   String?                      @map("embedding_model") // "text-embedding-3-small"
  embeddingVersion String?                      @map("embedding_version")
  lastEmbeddedAt   DateTime?                    @map("last_embedded_at")

  profileCompleteness Float @default(0.0) @map("profile_completeness") // 0-100
  qualityScore        Float @default(0.0) @map("quality_score") // AI-calculated

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  moderationLogs ModerationLog[]
  unlocks        Unlock[]
  applications   Application[]
  matchScores    MatchScore[]

  @@index([status])
  @@index([desiredSectors])
  @@map("candidate_profiles")
}

model Project {
  id        String  @id @default(cuid())
  founderId String  @map("founder_id")
  slug      String? @unique // SEO-friendly URL slug

  // Content
  name        String
  pitch       String  @db.Text // Short tagline
  description String? @db.Text // Full AI-analyzed text (optional, generated later)
  sector      String? // Fintech, Health, etc.
  stage       String? // Idea, MVP, Growth
  logoUrl     String? @map("logo_url")

  // Document source (uploaded by founder)
  documentUrl      String? @map("document_url")
  documentName     String? @map("document_name")
  documentMimeType String? @map("document_mime_type")

  // AI-generated summary blocks (6 blocs)
  aiSummary Json? @map("ai_summary") @db.JsonB

  // Identity (Step 1)
  country  String?
  city     String?
  location String? // Computed: "city, country"

  // Details (Step 2)
  scope String? // LOCAL, DIASPORA, HYBRID

  // Problem (Step 3)
  problem         String? @db.Text
  target          String? // Persona
  solutionCurrent String? @map("solution_current") @db.Text

  // Solution (Step 4)
  solutionDesc String? @map("solution_desc") @db.Text
  uvp          String? // Unique Value Proposition
  antiScope    String? @map("anti_scope") @db.Text

  // Market (Step 5)
  marketType    String? @map("market_type") // B2C, B2B, B2G, MARKETPLACE
  businessModel String? @map("business_model") // SUBSCRIPTION, COMMISSION, SALES, FREEMIUM, ADS
  competitors   String? @db.Text

  // Traction (Step 6)
  founderRole      String? @map("founder_role") // CEO, CTO, CPO, CMO, COO
  timeAvailability String? @map("time_availability") // 2-5H, 5-10H, 10-20H, FULLTIME
  traction         String? @db.Text

  // Cofounder (Step 7)
  lookingForRole String? @map("looking_for_role") // TECH, BIZ, PRODUCT, FINANCE
  collabType     String? @map("collab_type") // EQUITY, PAID, HYBRID
  vision         String? @db.Text

  // Project Details (legacy)
  teamSize      Int?      @map("team_size")
  fundingStatus String?   @map("funding_status") // "BOOTSTRAPPED", "SEED", "SERIES_A"
  techStack     String[]  @default([]) @map("tech_stack") // ["React", "Node.js"]
  websiteUrl    String?   @map("website_url")
  demoUrl       String?   @map("demo_url")
  deadline      DateTime? // Recruitment deadline

  // Requirements (legacy)
  requiredSkills   String[] @default([]) @map("required_skills")
  niceToHaveSkills String[] @default([]) @map("nice_to_have_skills")
  commitment       String? // "FULL_TIME", "PART_TIME", "FREELANCE"
  budget           Json?    @db.JsonB // {min: 500000, max: 2000000, currency: "XAF"}
  isRemote         Boolean  @default(false) @map("is_remote")
  isUrgent         Boolean  @default(false) @map("is_urgent")

  // Moderation
  status ModerationStatus @default(DRAFT)

  // AI Search & Scoring
  descriptionEmbedding Unsupported("vector(1024)")? @map("description_embedding")
  embeddingModel       String?                      @map("embedding_model")
  embeddingVersion     String?                      @map("embedding_version")
  lastEmbeddedAt       DateTime?                    @map("last_embedded_at")

  urgency      Int   @default(5) // 1-10
  qualityScore Float @default(0.0) @map("quality_score")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  founder          User                     @relation(fields: [founderId], references: [id], onDelete: Cascade)
  moderationLogs   ModerationLog[]
  unlocks          Unlock[]
  applications     Application[]
  matchScores      MatchScore[]
  userInteractions UserProjectInteraction[]
  boosts           Boost[]

  @@index([status])
  @@index([sector])
  @@index([requiredSkills])
  @@index([isUrgent])
  @@map("projects")
}

// --------------------------------------
// 3. AI Matching & Search
// --------------------------------------

model MatchScore {
  id String @id @default(cuid())

  candidateId String @map("candidate_id")
  projectId   String @map("project_id")

  // Detailed Scores (0-100)
  overallScore    Float @map("overall_score")
  skillsMatch     Float @map("skills_match")
  experienceMatch Float @map("experience_match")
  locationMatch   Float @map("location_match")
  culturalFit     Float @map("cultural_fit")

  // AI Reasoning
  aiReason     String? @db.Text
  aiConfidence Float   @map("ai_confidence") // 0-1

  // Metadata
  calculatedAt DateTime @default(now()) @map("calculated_at")
  modelVersion String   @map("model_version") // "gpt-4-turbo-2024-01"

  // Relations
  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([candidateId, projectId])
  @@index([projectId, overallScore(sort: Desc)]) // Top matches for project
  @@index([candidateId, overallScore(sort: Desc)]) // Top projects for candidate
  @@index([calculatedAt]) // Cleanup old scores
  @@map("match_scores")
}

model SearchLog {
  id     String  @id @default(cuid())
  userId String? @map("user_id") // Null if anonymous

  // Query
  query      String
  filters    Json?  @db.JsonB // {sector: "Fintech", location: "Douala"}
  searchType String @map("search_type") // "UNIVERSAL", "TEXT_FALLBACK", "SEMANTIC_HYBRID"

  // Results
  resultsCount Int      @map("results_count")
  topResultIds String[] @map("top_result_ids") // Top 10 IDs

  // User Interaction
  clickedResultId String? @map("clicked_result_id")
  clickPosition   Int?    @map("click_position") // Position in results (1-based)
  timeToClick     Int?    @map("time_to_click") // Milliseconds

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([query]) // Trending searches
  @@index([searchType, createdAt])
  @@index([userId, createdAt])
  @@map("search_logs")
}

// --------------------------------------
// 4. Moderation & Trust
// --------------------------------------

model ModerationLog {
  id String @id @default(cuid())

  // Targets (Polymorphic-ish via nullable FKs)
  candidateProfileId String? @map("candidate_profile_id")
  projectId          String? @map("project_id")

  // AI Result
  aiScore   Float   @map("ai_score") // 0.0 to 1.0 confidence
  aiReason  String? @map("ai_reason")
  aiPayload Json?   @map("ai_payload") @db.JsonB // Full LLM response

  // Decision
  status     ModerationStatus
  reviewedAt DateTime         @default(now()) @map("reviewed_at")

  // Relations
  candidateProfile CandidateProfile? @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("moderation_logs")
}

model AdminLog {
  id       String @id @default(cuid())
  adminId  String @map("admin_id")
  action   String // "OVERRIDE_MODERATION", "UPDATE_PROMPT"
  targetId String @map("target_id")
  details  Json?  @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@map("admin_logs")
}

// --------------------------------------
// 5. Monetization (Stripe)
// --------------------------------------

enum TransactionStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum TransactionType {
  SUBSCRIPTION
  UNLOCK
}

model Transaction {
  id     String @id @default(cuid())
  userId String @map("user_id")

  amount   Decimal           @db.Decimal(10, 2)
  currency String            @default("EUR")
  status   TransactionStatus @default(PENDING)
  type     TransactionType   @default(SUBSCRIPTION)

  // External Reference
  provider   String  @default("STRIPE")
  externalId String? @unique @map("external_id") // External Transaction ID

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlocks   Unlock[]
  auditLogs PaymentAuditLog[]

  @@map("transactions")
}

model PaymentAuditLog {
  id            String @id @default(cuid())
  transactionId String @map("transaction_id")
  event         String // "WEBHOOK_RECEIVED", "SIGNATURE_VALIDATED"
  payload       Json   @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("payment_audit_logs")
}

model Unlock {
  id            String @id @default(cuid())
  userId        String @map("user_id") // The Payer
  transactionId String @map("transaction_id")

  // What was unlocked?
  targetCandidateId String? @map("target_candidate_id")
  targetProjectId   String? @map("target_project_id")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction       @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  candidate   CandidateProfile? @relation(fields: [targetCandidateId], references: [id], onDelete: SetNull)
  project     Project?          @relation(fields: [targetProjectId], references: [id], onDelete: SetNull)

  @@unique([userId, targetCandidateId]) // Prevent double payment
  @@unique([userId, targetProjectId])
  @@map("unlocks")
}

// --------------------------------------
// 6. Applications / Matching
// --------------------------------------

enum ApplicationStatus {
  PENDING
  ACCEPTED // Founder wants to talk
  REJECTED
  IGNORED
}

model Application {
  id String @id @default(cuid())

  candidateId String @map("candidate_id")
  projectId   String @map("project_id")

  status  ApplicationStatus @default(PENDING)
  message String?           @db.Text // Optional cover note

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  candidate    CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation Conversation?

  @@unique([candidateId, projectId]) // One application per candidate per project
  @@index([projectId, status]) // Founder dashboard query
  @@index([candidateId]) // Candidate "My Applications" query
  @@map("applications")
}

// --------------------------------------
// 7. System Utilities
// --------------------------------------

enum NotificationType {
  SYSTEM
  APPLICATION_RECEIVED
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  MODERATION_ALERT
  DOCUMENT_ANALYZED
  DOCUMENT_ANALYSIS_FAILED
  PROFILE_PUBLISHED
  PROFILE_REVIEW
  PROFILE_UNLOCKED
  WELCOME
  ONBOARDING_REMINDER
  MESSAGE_RECEIVED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model Notification {
  id      String           @id @default(cuid())
  userId  String           @map("user_id")
  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false) @map("is_read")
  data    Json?            @db.JsonB // Link to Application ID or Project ID

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// --------------------------------------
// 8. User Behavior Tracking
// --------------------------------------

model UserProjectInteraction {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  projectId String @map("project_id")

  // Action type
  action String // VIEW, CLICK, SAVE, UNSAVE, APPLY, SKIP, SHARE, UNLOCK

  // Engagement depth
  dwellTimeMs Int?   @map("dwell_time_ms") // Time spent in ms
  scrollDepth Float? @map("scroll_depth") // 0.0 to 1.0

  // Context
  source   String? // FEED, SEARCH, DIRECT, NOTIFICATION
  position Int? // Position in feed when seen

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, action])
  @@index([userId, projectId])
  @@index([projectId, action])
  @@index([createdAt])
  @@map("user_project_interactions")
}

// --------------------------------------
// 9. Ads / Contenu Premium
// --------------------------------------

enum AdPlacement {
  FEED
  SIDEBAR
  BANNER
  SEARCH
}

enum AdEventType {
  IMPRESSION
  CLICK
}

model Ad {
  id String @id @default(cuid())

  // Contenu
  title       String
  description String? @db.Text
  imageUrl    String? @map("image_url")
  linkUrl     String? @map("link_url")
  ctaText     String? @map("cta_text")

  // Placement
  placement AdPlacement
  priority  Int         @default(5) // 1-10

  // Ciblage
  targetRoles   String[] @default([]) @map("target_roles")
  targetSectors String[] @default([]) @map("target_sectors")
  targetCities  String[] @default([]) @map("target_cities")
  targetStages  String[] @default([]) @map("target_stages")
  targetSkills  String[] @default([]) @map("target_skills")

  // Diffusion
  isActive  Boolean   @default(true) @map("is_active")
  startDate DateTime  @default(now()) @map("start_date")
  endDate   DateTime? @map("end_date")

  // Frequency capping
  maxImpressionsPerUserPerDay Int @default(3) @map("max_impressions_per_user_per_day")

  // Stats dénormalisées
  totalImpressions Int @default(0) @map("total_impressions")
  totalClicks      Int @default(0) @map("total_clicks")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  events AdEvent[]

  @@index([placement, isActive])
  @@index([startDate, endDate])
  @@map("ads")
}

model AdEvent {
  id     String  @id @default(cuid())
  adId   String  @map("ad_id")
  userId String? @map("user_id")

  type      AdEventType
  placement AdPlacement
  position  Int?

  // Viewport tracking
  viewportMs Int? @map("viewport_ms")

  source String?

  createdAt DateTime @default(now()) @map("created_at")

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId, type])
  @@index([userId, adId, createdAt])
  @@index([createdAt])
  @@map("ad_events")
}

model AdConfig {
  id                   String  @id @default("singleton")
  feedInsertEvery      Int     @default(8) @map("feed_insert_every")
  feedRandomize        Boolean @default(true) @map("feed_randomize")
  sidebarMaxAds        Int     @default(2) @map("sidebar_max_ads")
  bannerEnabled        Boolean @default(true) @map("banner_enabled")
  searchInsertPosition Int     @default(1) @map("search_insert_position")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ad_config")
}

// --------------------------------------
// 10. AI Configuration & Monitoring
// --------------------------------------

model AiConfig {
  id                   String   @id @default("singleton")
  defaultProvider      String   @default("DEEPSEEK") @map("default_provider")
  embeddingProvider    String   @default("JINA") @map("embedding_provider")
  providerPerAction    Json     @default("{}") @map("provider_per_action") @db.JsonB
  models               Json     @default("{}") @db.JsonB
  maxTokens            Int      @default(4096) @map("max_tokens")
  temperature          Float?
  moderationThresholds Json     @default("{\"publishMin\":0.7,\"rejectMax\":0.3}") @map("moderation_thresholds") @db.JsonB
  matchingWeights      Json     @default("{\"skills\":40,\"experience\":20,\"location\":15,\"culture\":25}") @map("matching_weights") @db.JsonB
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("ai_config")
}

model AiPrompt {
  id               String   @id @default(cuid())
  action           String   @unique
  content          String   @db.Text
  version          Int      @default(1)
  previousVersions Json     @default("[]") @map("previous_versions") @db.JsonB
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("ai_prompts")
}

model AiCallLog {
  id               String   @id @default(cuid())
  action           String
  provider         String
  model            String
  success          Boolean
  durationMs       Int      @map("duration_ms")
  inputTokens      Int?     @map("input_tokens")
  outputTokens     Int?     @map("output_tokens")
  estimatedCostUsd Float?   @map("estimated_cost_usd")
  error            String?  @db.Text
  resourceType     String?  @map("resource_type")
  resourceId       String?  @map("resource_id")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([provider])
  @@index([createdAt])
  @@index([success])
  @@map("ai_call_logs")
}

// --------------------------------------
// 11. User Visits / Session Tracking
// --------------------------------------

model UserVisit {
  id     String @id @default(cuid())
  userId String @map("user_id")

  // Device info
  ip        String?
  userAgent String? @map("user_agent")
  device    String? // MOBILE, DESKTOP, TABLET (parsed from UA)
  browser   String? // Chrome, Firefox, Safari...
  os        String? // Windows, Android, iOS...
  country   String? // Geo from IP (optional future)

  // Session timing
  loginAt    DateTime @default(now()) @map("login_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginAt])
  @@index([loginAt])
  @@index([userId, lastSeenAt])
  @@map("user_visits")
}

// --------------------------------------
// 12. FCM Push Notifications
// --------------------------------------

model FcmToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique // FCM registration token
  device    String? // DESKTOP, MOBILE, TABLET
  browser   String? // Chrome, Firefox, Safari...
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("fcm_tokens")
}

model PushConfig {
  id           String   @id @default("singleton")
  enabled      Boolean  @default(true)
  // Types de notifications pour lesquels le push est activé (toutes par défaut)
  enabledTypes String[] @default(["SYSTEM", "APPLICATION_RECEIVED", "APPLICATION_ACCEPTED", "APPLICATION_REJECTED", "MODERATION_ALERT", "DOCUMENT_ANALYZED", "DOCUMENT_ANALYSIS_FAILED", "PROFILE_PUBLISHED", "PROFILE_REVIEW", "PROFILE_UNLOCKED"]) @map("enabled_types")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("push_config")
}

model EmailConfig {
  id           String   @id @default("singleton")
  enabled      Boolean  @default(true)
  enabledTypes String[] @default(["SYSTEM", "APPLICATION_RECEIVED", "APPLICATION_ACCEPTED", "APPLICATION_REJECTED", "MODERATION_ALERT", "DOCUMENT_ANALYZED", "DOCUMENT_ANALYSIS_FAILED", "PROFILE_PUBLISHED", "PROFILE_REVIEW", "PROFILE_UNLOCKED", "WELCOME", "ONBOARDING_REMINDER", "MESSAGE_RECEIVED"]) @map("enabled_types")
  fromName     String   @default("MojiraX") @map("from_name")
  fromEmail    String   @default("noreply@mojirax.com") @map("from_email")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("email_configs")
}

model EmailLog {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  to        String
  subject   String
  brevoId   String?          @map("brevo_id")
  status    String           @default("SENT")
  error     String?
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@map("email_logs")
}

// --------------------------------------
// Filter Embeddings (Skills sémantiques)
// --------------------------------------

model FilterEmbedding {
  id         String                       @id @default(cuid())
  type       String // "SKILL"
  value      String // valeur brute ex: "React Native"
  label      String // label affichage
  embedding  Unsupported("vector(1024)")? @map("embedding")
  usageCount Int                          @default(0) @map("usage_count")
  updatedAt  DateTime                     @updatedAt @map("updated_at")

  @@unique([type, value])
  @@map("filter_embeddings")
}

// --------------------------------------
// 13. Messaging
// --------------------------------------

model Conversation {
  id                 String      @id @default(uuid())
  applicationId      String?     @unique @map("application_id")
  application        Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  founderId          String      @map("founder_id")
  founder            User        @relation("FounderConversations", fields: [founderId], references: [id], onDelete: Cascade)
  candidateId        String      @map("candidate_id")
  candidate          User        @relation("CandidateConversations", fields: [candidateId], references: [id], onDelete: Cascade)
  lastMessageAt      DateTime?   @map("last_message_at")
  lastMessagePreview String?     @map("last_message_preview")
  messages           Message[]
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@unique([founderId, candidateId])
  @@map("conversations")
}

model Message {
  id              String            @id @default(uuid())
  conversationId  String            @map("conversation_id")
  conversation    Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String            @map("sender_id")
  sender          User              @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  clientMessageId String?           @unique @map("client_message_id")
  content         String?
  fileUrl         String?           @map("file_url")
  fileName        String?           @map("file_name")
  fileSize        Int?              @map("file_size")
  fileMimeType    String?           @map("file_mime_type")
  status          MessageStatus     @default(SENT)
  deliveredAt     DateTime?         @map("delivered_at")
  readAt          DateTime?         @map("read_at")
  reactions       MessageReaction[]
  createdAt       DateTime          @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation("MessageReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String   @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

// --------------------------------------
// Landing Page Content
// --------------------------------------

model PricingPlan {
  id          String   @id @default(cuid())
  name        Json     @db.JsonB
  price       Decimal  @default(0) @db.Decimal(10, 2)
  period      Json     @db.JsonB
  currency    String   @default("EUR")
  description Json?    @db.JsonB
  features    Json     @db.JsonB
  isPopular   Boolean  @default(false) @map("is_popular")
  isActive    Boolean  @default(true) @map("is_active")
  order       Int      @default(0)
  ctaLabel    Json     @db.JsonB @map("cta_label")
  stripePriceId String?   @unique @map("stripe_price_id")
  planKey       UserPlan? @map("plan_key")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, order])
  @@map("pricing_plans")
}

model Faq {
  id        String   @id @default(cuid())
  question  Json     @db.JsonB
  answer    Json     @db.JsonB
  isActive  Boolean  @default(true) @map("is_active")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, order])
  @@map("faqs")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      Json     @db.JsonB
  location  String
  quote     Json     @db.JsonB
  imageUrl  String   @map("image_url")
  isActive  Boolean  @default(true) @map("is_active")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, order])
  @@map("testimonials")
}

// 10. Profile Views (who viewed my profile)
model ProfileView {
  id        String   @id @default(cuid())
  viewerId  String   @map("viewer_id")
  viewedId  String   @map("viewed_id")
  createdAt DateTime @default(now()) @map("created_at")

  viewer User @relation("ProfileViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  viewed User @relation("ProfileViewed", fields: [viewedId], references: [id], onDelete: Cascade)

  @@index([viewedId, createdAt])
  @@index([viewerId, createdAt])
  @@unique([viewerId, viewedId])
  @@map("profile_views")
}

// 11. Boosts (visibility boost for projects)
model Boost {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  startedAt DateTime @default(now()) @map("started_at")
  expiresAt DateTime @map("expires_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([projectId, expiresAt])
  @@map("boosts")
}
